// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("ADMIN")
  
  profile       Profile?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  title        String
  shortBio     String?  @db.Text
  fullBio      String?  @db.Text
  resumeUrl    String?
  location     String?
  phone        String?
  email        String?
  githubUrl    String?
  linkedinUrl  String?
  websiteUrl   String?
  avatarUrl    String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Technology {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  icon              String?
  
  skills                Skill[]
  projectTechnology     ProjectTechnology[]
  experienceTechnology  ExperienceTechnology[]
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Skill {
  id           String      @id @default(cuid())
  type         String      @default("HARD") // "HARD" | "SOFT"
  name         String?     // Used for SOFT skills
  
  technologyId String?
  technology   Technology?  @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  level        String?     // e.g., "Beginner", "Intermediate", "Advanced", "Expert"
  category     String?     // e.g., "Frontend", "Backend", "DevOps"
  isPublic     Boolean     @default(true)
  displayOrder Int         @default(0)
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Experience {
  id             String    @id @default(cuid())
  title          String
  company        String
  companyLogo    String?
  location       String?
  type           String?   // e.g., Full-time, Freelance
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  description    String?   @db.Text
  responsibilities String? @db.Text
  
  technologies   ExperienceTechnology[]
  projects       Project[]
  
  educationId    String?
  education      Education? @relation(fields: [educationId], references: [id], onDelete: SetNull)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ExperienceTechnology {
  experienceId String
  technologyId String
  
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  
  @@id([experienceId, technologyId])
}

model Education {
  id              String    @id @default(cuid())
  institution     String
  institutionLogo String?
  degree          String
  major           String?
  startDate       DateTime
  endDate         DateTime?
  gpa             String?
  predicate       String?
  description     String?   @db.Text
  finalProjectId  String?
  
  projects        Project[]
  experiences     Experience[]
  finalProject    Research? @relation("FinalProject", fields: [finalProjectId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Certificate {
  id             String    @id @default(cuid())
  name           String
  issuer         String
  issueDate      DateTime
  expiryDate     DateTime?
  credentialId   String?
  credentialUrl  String?
  image          String?
  issuerLogo     String?
  isPublic       Boolean   @default(true)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Research {
  id             String    @id @default(cuid())
  title          String
  category       String    @default("PUBLICATION") // e.g. "PUBLICATION", "DATASET"
  publisher      String
  publishDate    DateTime
  description    String?   @db.Text
  url            String?
  image          String?
  authors        String?
  isPublic       Boolean   @default(true)
  
  education      Education[] @relation("FinalProject")
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Project {
  id               String               @id @default(cuid())
  title            String
  slug             String               @unique
  thumbnail        String?
  shortDescription String?              @db.Text
  fullDescription  String?              @db.Text
  background       String?              @db.Text
  objectives       String?              @db.Text
  solutions        String?              @db.Text
  architecture     String?              @db.Text
  challenges       String?              @db.Text
  lessons          String?              @db.Text
  repositoryUrl    String?
  demoUrl          String?
  isPublished      Boolean              @default(false)
  isFeatured       Boolean              @default(false)
  
  experienceId     String?
  experience       Experience?          @relation(fields: [experienceId], references: [id], onDelete: SetNull)
  educationId      String?
  education        Education?           @relation(fields: [educationId], references: [id], onDelete: SetNull)
  
  images           ProjectImage[]
  technologies     ProjectTechnology[]
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model ProjectImage {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageUrl     String
  altText      String?
  displayOrder Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProjectTechnology {
  projectId    String
  technologyId String
  
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())

  @@id([projectId, technologyId])
}


model Visitor {
  id        String   @id @default(cuid())
  ipAddress String?
  
  // Data detail perangkat
  userAgent String?
  browser   String?
  os        String?
  device    String?
  
  // Lokasi
  country   String?
  city      String?
  
  // Navigasi
  path      String?
  referer   String?
  
  visitedAt DateTime @default(now())
}

model ResumeSetting {
  id               String   @id @default(cuid())
  
  showExperience   Boolean  @default(true)
  showEducation    Boolean  @default(true)
  showProjects     Boolean  @default(true)
  showCertificates Boolean  @default(false)
  showSkills       Boolean  @default(true)
  
  sectionOrder     String?  @db.Text 
  isAtsOptimized   Boolean  @default(true)
  
  updatedAt        DateTime @updatedAt
}

model SiteSetting {
  id                String   @id @default(cuid())
  
  siteName          String   @default("Personal Portfolio")
  logoUrl           String?
  faviconUrl        String?
  
  seoTitle          String?
  seoDescription    String?  @db.Text
  openGraphImage    String?
  twitterHandle     String?
  
  googleAnalyticsId String?
  maintenanceMode   Boolean  @default(false)
  
  footerText        String?  @db.Text
  copyrightName     String?
  
  updatedAt         DateTime @updatedAt
}
